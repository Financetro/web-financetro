rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ Master Governance Function (Bypasses all client restrictions)
    function userIsAdmin() {
      return request.auth != null && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    // 🌐 Global Settings Access (Everyone needs to read this for maintenance status)
    match /settings/{document=**} {
      allow read: if true;
    }

    match /users/{userId} {
      // 1. MOBILE/WEB LOGIN: Allow unauthenticated email existence check
      allow list: if (request.query.limit <= 1) || userIsAdmin();
      
      // 2. PROFILE ACCESS: Allow users to see own data OR Admin to see everyone
      allow get: if (request.auth != null && (request.auth.uid == userId || userIsAdmin()));
      
      // 3. PROFILE UPDATE: Allow users to edit own data OR Admin master override
      allow write: if (request.auth != null && (request.auth.uid == userId || userIsAdmin()));
      
      // 4. DEEP SUB-COLLECTIONS: Allow deep access to transactions, goals, etc.
      match /{allPaths=**} {
        allow read, write: if (request.auth != null && (request.auth.uid == userId || userIsAdmin()));
      }
    }
    
    // 🔥 LEDGER GLOBAL SEARCH (Supports 'collectionGroup' queries across all users)
    match /{path=**}/transactions/{transactionId} {
        allow read: if userIsAdmin();
    }
    
    // Root level fallback for Admin global monitoring
    match /{document=**} {
      allow read: if userIsAdmin();
    }
  }
}
