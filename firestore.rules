rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow unauthenticated query for a single email (for login error messages)
      allow list: if request.query.limit <= 1;
      
      // Allow user to read and write their own profile
      allow get, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow user to access ALL of their own subcollections (transactions, goals, schedules, etc.)
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
